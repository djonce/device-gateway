# Copy to .env and edit. docker compose reads it automatically.
# Leaving the admin password / provision key empty runs in OPEN mode (dev only).

LIGHT_ADMIN_USER=admin
LIGHT_ADMIN_PASSWORD=change-me-to-a-strong-password
LIGHT_PROVISION_KEY=change-me-to-a-strong-enrollment-key

# Optional voice pipeline (leave empty for the echo placeholder)
# LIGHT_VOICE_LLM_URL=https://api.openai.com/v1/chat/completions
# LIGHT_VOICE_LLM_KEY=sk-...
# LIGHT_VOICE_LLM_MODEL=gpt-4o-mini
# LIGHT_VOICE_ASR_URL=
# LIGHT_VOICE_TTS_URL=
